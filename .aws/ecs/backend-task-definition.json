{
  "family": "glowingstar-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::402961397995:role/glowingstar-ecs-express-execution-role",
  "taskRoleArn": "arn:aws:iam::402961397995:role/glowingstar-ecs-express-execution-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "402961397995.dkr.ecr.us-east-1.amazonaws.com/glowingstar/backend:bootstrap",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DISABLE_AGENT_CHAINING",
          "value": "true"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-2"
        },
        {
          "name": "AWS_SAINTPAUL_ASSETS_BUCKET",
          "value": "saintpaul-assets-402961397995-us-east-2"
        },
        {
          "name": "AWS_SAINTPAUL_SESSIONS_TABLE",
          "value": "saintpaul_sessions_v1"
        },
        {
          "name": "AWS_SAINTPAUL_EVENTS_TABLE",
          "value": "saintpaul_events_v1"
        },
        {
          "name": "AWS_SAINTPAUL_ERRORS_TABLE",
          "value": "saintpaul_errors_v1"
        },
        {
          "name": "AWS_USF_SESSIONS_TABLE",
          "value": "usf_sessions_v1"
        },
        {
          "name": "AWS_USF_EVENTS_TABLE",
          "value": "usf_events_v1"
        },
        {
          "name": "AWS_USF_ERRORS_TABLE",
          "value": "usf_errors_v1"
        },
        {
          "name": "AWS_USF_RECORDINGS_BUCKET",
          "value": "usf-defense-recordings-402961397995-us-east-2"
        }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:402961397995:secret:glowingstar/backend/openai-api-key-qpVq8l"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/glowingstar-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
